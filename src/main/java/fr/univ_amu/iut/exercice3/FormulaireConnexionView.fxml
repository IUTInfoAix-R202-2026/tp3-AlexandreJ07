<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane xmlns="http://javafx.com/javafx/25"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="fr.univ_amu.iut.exercice3.FormulaireConnexionController"
          stylesheets="@FormulaireConnexion.css">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Identifiant :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>

    <TextField fx:id="champIdentifiant"
               GridPane.rowIndex="0"
               GridPane.columnIndex="1"/>

    <Label text="Mot de passe :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

    <PasswordField fx:id="champMotDePasse"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="1"/>

    <HBox spacing="10"
          GridPane.rowIndex="2"
          GridPane.columnIndex="1">

<Button fx:id="boutonOk"
        text="OK"
        onAction="#valider"/>

<Button fx:id="boutonAnnuler"
        text="Annuler"
        onAction="#annuler"/>
    </HBox>

    <Label fx:id="labelMessage"
           styleClass="message"
           GridPane.rowIndex="3"
           GridPane.columnIndex="0"
           GridPane.columnSpan="2"/>

</GridPane>